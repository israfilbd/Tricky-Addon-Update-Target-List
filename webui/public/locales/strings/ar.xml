    <string name="help_set_keybox">تعيين صندوق المفاتيح</string>
    <string name="help_set_keybox_description">استبدال صندوق مفاتيح TrickyStore بما يلي:</string>
    <string name="help_set_keybox_aosp">AOSP - صندوق المفاتيح الافتراضي يأتي مع TrickyStore.</string>
    <string name="help_set_keybox_unknown">غير معروف - توقيع ذاتي وغير صالح لنظام سلامة Play</string>
    <string name="help_set_keybox_local">محلي - حدد صندوق المفاتيح من جهازك.</string>
