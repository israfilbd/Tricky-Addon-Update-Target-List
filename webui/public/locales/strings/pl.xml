    <string name="help_deselect_unnecessary">Odznacz niepotrzebne</string>
    <string name="help_deselect_unnecessary_description">Kategoria niepotrzebne: moduł Xposed, menedżer root, aplikacje związane z rootem i ogólne aplikacje, które nigdy nie sprawdzają stanu bootloadera. Funkcja wymaga połączenia internetowego.</string>
